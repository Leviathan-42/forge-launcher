{
  "name": "forge-launcher",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "native:dev": "scripts/run-native-app.sh",
    "native:run-raw": "swift run --package-path macos/ForgeNative ForgeNative",
    "native:build": "swift build --package-path macos/ForgeNative -c release",
    "native:test": "swift test --package-path macos/ForgeNative",
    "native:check": "swift build --package-path macos/ForgeNative -c debug && npm run native:test",
    "check:all": "npm run check && npm run build && npm run rust:fmt && npm run rust:check && npm run rust:clippy && npm run native:check",
    "kill": "scripts/forge-kill.sh",
    "doctor": "scripts/forge-doctor.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-static": "^1.16.0",
    "svelte": "^5.55.9"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "svelte-check": "^4.4.8",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.3"
  }
}
