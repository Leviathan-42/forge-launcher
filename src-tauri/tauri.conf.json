{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "Forge Launcher",
  "version": "0.1.0",
  "identifier": "com.forgelauncher.app",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Forge Launcher",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost https://asset.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline' asset: http://asset.localhost https://asset.localhost; script-src 'self' 'unsafe-inline' asset: http://asset.localhost https://asset.localhost"
    },
    "macOSPrivateApi": true
  },

  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "public.app-category.games",
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "frameworks": []
    }
  }
}
